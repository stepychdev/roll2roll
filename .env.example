# ─── Shared config (loaded for all modes) ───
# Usage:
#   npm run dev:devnet   →  loads .env + .env.devnet
#   npm run dev:mainnet  →  loads .env + .env.mainnet
#   npm run build:mainnet →  production build for mainnet

# Jupiter API key (get yours at https://portal.jup.ag)
VITE_JUPITER_API_KEY=your-api-key-here

# Firebase (chat)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Mode-specific files (create these): ───
# .env.devnet:
#   VITE_NETWORK=devnet
#   VITE_RPC_URL=
#
# .env.mainnet:
#   VITE_NETWORK=mainnet
#   VITE_RPC_URL=<your-mainnet-rpc>
#   VITE_PROGRAM_ID=<mainnet-program-id>
#   VITE_TREASURY_ATA=<mainnet-treasury-ata>
#   VITE_ADMIN_PUBKEY=<mainnet-admin-pubkey>
